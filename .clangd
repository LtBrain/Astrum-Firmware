CompileFlags:
  CompilationDatabase: build/Debug

  Add:
    - -mcpu=cortex-m33
    - -mthumb

    # DO NOT use --target with GCC toolchain
    # - --target=arm-none-eabi   ❌ removed

    # Standard library includes (kept, but optional if query-driver works)

    - -isystem
    - C:/ST/STM32CubeCLT_1.19.0/GNU-tools-for-STM32/arm-none-eabi/include/c++/11.3.1

    - -isystem
    - C:/ST/STM32CubeCLT_1.19.0/GNU-tools-for-STM32/arm-none-eabi/include/c++/11.3.1/arm-none-eabi

    - -isystem
    - C:/ST/STM32CubeCLT_1.19.0/GNU-tools-for-STM32/arm-none-eabi/include/c++/11.3.1/backward

    - -isystem
    - C:/ST/STM32CubeCLT_1.19.0/GNU-tools-for-STM32/arm-none-eabi/include